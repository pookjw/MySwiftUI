--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-xros-simulator, arm64-xros-simulator ]
install-name:    '/System/Library/PrivateFrameworks/CoreRE.framework/CoreRE'
swift-abi-version: 7
exports:
  - targets:         [ x86_64-xros-simulator, arm64-xros-simulator ]
    symbols:              [ _REEntityGetSceneNullable,
    _RESceneFindEntity,
    _RESelectableSceneContentIdentifierGetComponentType,
    _REEntityGetOrAddComponentByClass,
    _RESelectableSceneContentIdentifierComponentSetIdentifier,
    _RESelectableSceneContentIdentifierComponentGetIdentifier,
    _RELinkedOnOrAfterFall2020OSVersions,
    _RELinkedOnOrAfterFall2021OSVersions,
    _RELinkedOnOrAfterFall2022OSVersions,
    _RELinkedOnOrAfterFall2024OSVersions,
    _RELinkedOnOrAfterFall2025OSVersions,
    _RELinkedOnOrAfterVisionOS1_1AlignedOSVersions,
    _RERenderOptionsComponentGetComponentType,
    _RESceneSpaceRootComponentGetComponentType,
    _REEntityGetComponentByClass,
    _RESceneSpaceRootComponentGetIsSelfInImmersiveSpace,
    _RESceneSpaceRootComponentSetIsSelfInImmersiveSpace,
    _REImmersiveSpaceTrackerComponentGetComponentType,
    _RERenderOptionsComponentOverrideContributeToCombinedVignetting ]
    objc-classes:         [ BSAnimationSettings ]
    objc-ivars:           [  ]
...
